{
  "openapi": "3.0.0",
  "info": {
    "title": "API - Sistema de Solicitações (TCC)",
    "version": "1.2.0",
    "description": "API completa do TCC. Contempla Autenticação 2FA, Portaria de Usuários (Aprovação Master), Hierarquia de Cargos (1-13), Formulários Dinâmicos, Motor de Aprovação com prevenção de auto-aprovação, isolamento por área e Painel de Gestão Global."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/users": {
      "get": {
        "tags": ["Usuários"],
        "summary": "Listar todos os usuários (MASTER)",
        "description": "Retorna todos os usuários para gestão na Portaria. Apenas acessível por MASTER.",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Lista de usuários retornada" } }
      },
      "post": {
        "tags": ["Usuários"],
        "summary": "Registrar novo usuário",
        "description": "O primeiro usuário é MASTER e isApproved:true. Os demais são USER e isApproved:false (pendentes).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "areaId": { "type": "string", "format": "uuid", "nullable": true }
                },
                "required": ["name", "email", "password"]
              }
            }
          }
        },
        "responses": { "201": { "description": "Usuário criado" } }
      }
    },
    "/users/{id}": {
      "patch": {
        "tags": ["Usuários"],
        "summary": "Atualizar Usuário / Portaria (MASTER)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "access": { "type": "string", "enum": ["USER", "ADMIN", "MASTER"] },
                  "areaId": { "type": "string", "format": "uuid", "nullable": true },
                  "isApproved": { "type": "boolean" },
                  "approvalLevel": { "type": "integer", "minimum": 1, "maximum": 13, "description": "1:Estagiário ... 13:Presidente" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Usuário atualizado" } }
      }
    },
    "/users/login": {
      "post": {
        "tags": ["Usuários"],
        "summary": "Autenticação",
        "description": "Verifica se o usuário existe, se a senha está correta e se isApproved é true.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "gabriel@teste.com" },
                  "password": { "type": "string", "example": "Senha@123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login realizado, retorna JWT" },
          "401": { "description": "Credenciais inválidas ou usuário não aprovado na Portaria" }
        }
      }
    },
    "/tokens/send": {
      "post": {
        "tags": ["Tokens (2FA)"],
        "summary": "Solicitar código 2FA",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "email": { "type": "string" } } }
            }
          }
        },
        "responses": { "200": { "description": "Código enviado" } }
      }
    },
    "/tokens/verify": {
      "post": {
        "tags": ["Tokens (2FA)"],
        "summary": "Verificar código 2FA",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "informedCode": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Conta verificada" } }
      }
    },
    "/areas": {
      "get": {
        "tags": ["Áreas"],
        "summary": "Listar Áreas",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Lista de áreas" } }
      },
      "post": {
        "tags": ["Áreas"],
        "summary": "Criar Área (MASTER)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" } } } } }
        },
        "responses": { "201": { "description": "Criado" } }
      }
    },
    "/solicitations": {
      "get": {
        "tags": ["Solicitações"],
        "summary": "Listar Solicitações",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "onlyArea",
            "in": "query",
            "description": "Se true, filtra apenas solicitações da área do ADMIN logado. Útil para a tela de Configuração.",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": { "200": { "description": "Lista retornada" } }
      },
      "post": {
        "tags": ["Solicitações"],
        "summary": "Criar Molde de Solicitação (ADMIN/MASTER)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "name": { "type": "string" }, "areaId": { "type": "string", "format": "uuid" } }
              }
            }
          }
        },
        "responses": { "201": { "description": "Criado" } }
      }
    },
    "/solicitations/{id}/form": {
      "get": {
        "tags": ["Solicitações"],
        "summary": "Obter estrutura completa do formulário",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "JSON com seções e inputs" } }
      }
    },
    "/sections": {
      "post": {
        "tags": ["Seções"],
        "summary": "Criar Seção no Formulário (ADMIN)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "solicitationId": { "type": "string", "format": "uuid" },
                  "title": { "type": "string" },
                  "order": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Criado" } }
      }
    },
    "/inputs": {
      "post": {
        "tags": ["Inputs"],
        "summary": "Criar Campo na Seção (ADMIN)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sectionId": { "type": "string", "format": "uuid" },
                  "type": { "type": "string", "enum": ["text", "longtext", "cnpj", "tel", "number", "email", "date", "checkbox", "radio", "select"] },
                  "question": { "type": "string" },
                  "name": { "type": "string" },
                  "order": { "type": "integer" },
                  "isRequired": { "type": "boolean" },
                  "options": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Criado" } }
      }
    },
    "/workflows": {
      "get": {
        "tags": ["Workflows"],
        "summary": "Listar Solicitações Criadas pelo Usuário (Dashboard)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Lista de solicitações criadas pelo usuário logado" } }
      },
      "post": {
        "summary": "Enviar Solicitação (Criar Workflow)",
        "tags": ["Workflows"],
        "security": [{ "bearerAuth": [] }],
        "description": "Salva respostas e gera automaticamente a fila de aprovação (hierárquica + fixa), ignorando o criador se ele possuir o nível exigido.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "solicitationId": { "type": "string", "format": "uuid" },
                  "title": { "type": "string" },
                  "answers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "inputId": { "type": "string", "format": "uuid" },
                        "value": { "type": "string" }
                      }
                    }
                  }
                },
                "required": ["solicitationId", "title", "answers"]
              }
            }
          }
        },
        "responses": { "201": { "description": "Workflow criado." } }
      }
    },
    "/workflows/management": {
      "get": {
        "tags": ["Workflows"],
        "summary": "Gestão de Workflows (ADMIN / MASTER)",
        "description": "Retorna uma lista de workflows para a tela de gestão. Se MASTER, retorna tudo. Se ADMIN, retorna os workflows pertencentes à área do admin.",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Lista filtrada de workflows para gestão" } }
      }
    },
    "/workflows/{id}": {
      "get": {
        "tags": ["Workflows"],
        "summary": "Detalhes do Workflow (Timeline)",
        "description": "Retorna os dados da solicitação, respostas e status de todos os aprovadores.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Objeto completo do workflow" } }
      }
    },
    "/config-approvals/{solicitationId}": {
      "get": {
        "tags": ["Aprovações (Config)"],
        "summary": "Obter Regra Hierárquica",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "solicitationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Retorna level e fallback" } }
      },
      "post": {
        "summary": "Setar Regra Hierárquica",
        "tags": ["Aprovações (Config)"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "solicitationId": { "type": "string", "format": "uuid" },
                  "necessaryApproverLevel": { "type": "integer", "nullable": true },
                  "ifNotHaveApproverLevel": {
                    "type": "string",
                    "enum": ["NO_CONTINUE", "CONTINUE", "CHECK_ONE_MORE_LVL_AND_CONTINUE", "CHECK_ONE_MORE_LVL_AND_NO_CONTINUE"],
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Salvo" } }
      }
    },
    "/flow-approvals/{solicitationId}": {
      "get": {
        "tags": ["Aprovações (Config)"],
        "summary": "Obter Fluxo Fixo",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "solicitationId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Retorna array de usuários da fila" } }
      },
      "post": {
        "summary": "Setar Fluxo Fixo",
        "tags": ["Aprovações (Config)"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "solicitationId": { "type": "string", "format": "uuid" },
                  "flows": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "userId": { "type": "string", "format": "uuid" },
                        "order": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Fila salva" } }
      }
    },
    "/approvals/me": {
      "get": {
        "tags": ["Aprovações (Ação)"],
        "summary": "Minhas Pendências",
        "description": "Retorna as aprovações pendentes de onde o usuário logado é o aprovador da vez.",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Lista para a Dashboard" } }
      }
    },
    "/approvals/action": {
      "post": {
        "summary": "Aprovar ou Rejeitar",
        "tags": ["Aprovações (Ação)"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "approvalId": { "type": "string", "format": "uuid" },
                  "action": { "type": "string", "enum": ["APPROVED", "REJECTED"] },
                  "comments": { "type": "string", "nullable": true }
                },
                "required": ["approvalId", "action"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Parecer registrado." } }
      }
    }
  }
}
